<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.hrms.attendance.infrastructure.mapper.LeaveTypeMapper">

    <resultMap id="LeaveTypeResultMap" type="com.company.hrms.attendance.infrastructure.po.LeaveTypePO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="code" property="code"/>
        <result column="unit" property="unit"/>
        <result column="is_paid" property="isPaid"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, code, unit, is_paid, created_at, updated_at, created_by, updated_by
    </sql>

    <select id="selectById" resultMap="LeaveTypeResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM leave_types
        WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="LeaveTypeResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM leave_types
        WHERE code = #{code}
    </select>

    <select id="selectAll" resultMap="LeaveTypeResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM leave_types
    </select>

    <insert id="insert">
        INSERT INTO leave_types (
            id, name, code, unit, is_paid, created_at, updated_at, created_by, updated_by
        ) VALUES (
            #{id}, #{name}, #{code}, #{unit}, #{isPaid}, #{createdAt}, #{updatedAt}, #{createdBy}, #{updatedBy}
        )
    </insert>

    <update id="update">
        UPDATE leave_types SET
            name = #{name},
            code = #{code},
            unit = #{unit},
            is_paid = #{isPaid},
            updated_at = #{updatedAt},
            updated_by = #{updatedBy}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM leave_types WHERE id = #{id}
    </delete>

</mapper>
