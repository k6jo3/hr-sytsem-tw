# HRMS 部署環境變數
# 複製此檔為 .env 並填入實際值

# Docker Image 設定
DOCKER_REGISTRY=ghcr.io
DOCKER_REPO=k6jo3/hr-system-2
IMAGE_TAG=latest

# 資料庫
DB_USERNAME=hrms_user
DB_PASSWORD=hrms_password

# JWT
JWT_SECRET=your-256-bit-secret-key-for-jwt-token-generation-must-be-at-least-256-bits-long

# HTTP Port（對外）
HTTP_PORT=80
